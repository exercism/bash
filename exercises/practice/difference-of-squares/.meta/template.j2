{{ header }}
{% for idx, case in cases %}
@test "{{ case["description"] }}" {
  {% if idx == 0 %}# {% endif %}[[ $BATS_RUN_SKIPPED == "true" ]] || skip
  run bash {{ solution }} {{
    case["property"] | camel_to_snake | replace("difference_of_squares", "difference")
  }} {{ case["input"]["number"] }}
  assert_success
  assert_output "{{ case["expected"] }}"
}
{% endfor %}
